{
  "name": "aulasync-pro",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/fix-prisma-permissions.mjs && prisma generate && prisma db push --accept-data-loss && prisma db seed && next build",
    "start": "next start -H 0.0.0.0",
    "db:push": "prisma db push --accept-data-loss",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "deploy:setup": "node scripts/fix-prisma-permissions.mjs && prisma generate && prisma db push --accept-data-loss && prisma db seed && next build",
    "postinstall": "prisma generate && node scripts/fix-prisma-permissions.mjs",
    "prisma:permissions": "node scripts/fix-prisma-permissions.mjs"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.8.2",
    "bcryptjs": "^3.0.2",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "google-auth-library": "^10.5.0",
    "googleapis": "^150.0.1",
    "jose": "^6.0.11",
    "lucide-react": "^0.511.0",
    "next": "^15.3.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.3.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "prisma": "^6.8.2",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
