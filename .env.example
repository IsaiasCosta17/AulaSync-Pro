# PostgreSQL/Supabase: use Connect > Session pooler (porta 5432)
DATABASE_URL="postgresql://postgres.PROJECT_REF:SENHA_CODIFICADA@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require&connection_limit=3&connect_timeout=5&pool_timeout=5"

# Administrador inicial
ADMIN_NAME="Administrador"
ADMIN_EMAIL="admin@seudominio.com"
ADMIN_PASSWORD="defina-uma-senha-forte"

# Segredo aleatório com pelo menos 32 caracteres
AUTH_SECRET="substitua-por-um-segredo-aleatorio-com-32-caracteres"
# Base64 de exatamente 32 bytes. Preserve esta chave após conectar contas Google.
TOKEN_ENCRYPTION_KEY="substitua-por-uma-chave-base64-valida-de-32-bytes"

# OAuth 2.0 Web Application no Google Cloud
GOOGLE_CLIENT_ID="seu-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="seu-client-secret"
GOOGLE_REDIRECT_URI_DRIVE="https://universosmixcursos.com/api/oauth/google/drive/callback"
GOOGLE_REDIRECT_URI_YOUTUBE="https://universosmixcursos.com/api/oauth/google/youtube/callback"

# URL pública sem barra no final
NEXT_PUBLIC_APP_URL="https://universosmixcursos.com"

# Controles operacionais opcionais
MAX_CONCURRENT_DRIVE_STREAMS_PER_ACCOUNT="3"
UPLOAD_CHUNK_SIZE_MB="8"
UPLOAD_MAX_RETRIES="8"
UPLOAD_REQUEST_TIMEOUT_MS="120000"
