# Banco PostgreSQL persistente (Supabase, Neon ou outro provedor)
DATABASE_URL="postgresql://usuario:senha@host:5432/banco?sslmode=require"

# Login inicial (usado por prisma/seed.ts)
ADMIN_NAME="Administrador"
ADMIN_EMAIL="admin@aulasync.pro"
ADMIN_PASSWORD="troque-esta-senha"

# Gere com: openssl rand -base64 32
AUTH_SECRET="substitua-por-uma-chave-com-pelo-menos-32-caracteres"
# Chave Base64 de 32 bytes para AES-256-GCM: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY="substitua-por-uma-chave-base64-de-32-bytes"

# OAuth 2.0 Web Application no Google Cloud
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI_DRIVE="http://localhost:3000/api/oauth/google/drive/callback"
GOOGLE_REDIRECT_URI_YOUTUBE="http://localhost:3000/api/oauth/google/youtube/callback"

# Controles operacionais
MAX_PARALLEL_UPLOAD_JOBS="3"
UPLOAD_CHUNK_SIZE_MB="8"
UPLOAD_MAX_RETRIES="8"
UPLOAD_REQUEST_TIMEOUT_MS="120000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
